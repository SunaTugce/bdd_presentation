Step definition

# tests/step_defs/test_notes_steps.py

from pytest_bdd import scenarios, given, when, then, parsers

scenarios("../../features/notes_management.feature")


@given("an authenticated user exists")
def authenticated_user_exists(context, notes_service):
    context["user"] = notes_service.create_authenticated_user()


@when(parsers.parse('the user creates a note with title "{title}" and description "{description}"'))
def user_creates_note(context, notes_service, title, description):
    context["created_note"] = notes_service.create_note_for_user(
        token=context["user"]["token"],
        title=title,
        description=description,
    )


@then("the note should be created successfully")
def note_should_be_created_successfully(context):
    response = context["created_note"]["response"]
    assert response.status_code in [200, 201]
    assert context["created_note"]["note_id"] is not None


@then("the note should be available in the user's notes list")
def note_should_be_available_in_list(context, notes_service):
    assert notes_service.note_exists_in_list(
        token=context["user"]["token"],
        note_id=context["created_note"]["note_id"],
    )



