# tests/clients/notes_client.py

from tests.clients.base_api_client import BaseApiClient


class NotesClient(BaseApiClient):
    def create_note(self, token: str, title: str, description: str, category: str = "Home"):
        return self.post(
            "/notes",
            token=token,
            json={
                "title": title,
                "description": description,
                "category": category,
            },
        )

    def get_all_notes(self, token: str):
        return self.get("/notes", token=token)

    def get_note_by_id(self, token: str, note_id: str):
        return self.get(f"/notes/{note_id}", token=token)

    def update_note(self, token: str, note_id: str, title: str, description: str, category: str = "Home"):
        return self.put(
            f"/notes/{note_id}",
            token=token,
            json={
                "title": title,
                "description": description,
                "category": category,
            },
        )

    def delete_note(self, token: str, note_id: str):
        return self.delete(f"/notes/{note_id}", token=token)


Service layer
BDD açısından en değerli katman burası. Step definitionların şişmesini engeller.
# tests/services/notes_service.py

import uuid

from tests.clients.auth_client import AuthClient
from tests.clients.notes_client import NotesClient


class NotesService:
    def __init__(self, base_url: str):
        self.auth_client = AuthClient(base_url)
        self.notes_client = NotesClient(base_url)

    def create_authenticated_user(self) -> dict:
        unique = uuid.uuid4().hex[:8]
        email = f"bdd_user_{unique}@test.com"
        password = "Password123!"

        register_response = self.auth_client.register_user(
            name="BDD User",
            email=email,
            password=password,
        )

        login_response = self.auth_client.login_user(
            email=email,
            password=password,
        )

        token = login_response.json()["data"]["token"]

        return {
            "email": email,
            "password": password,
            "token": token,
            "register_response": register_response,
            "login_response": login_response,
        }

    def create_note_for_user(self, token: str, title: str, description: str) -> dict:
        response = self.notes_client.create_note(
            token=token,
            title=title,
            description=description,
        )

        note = response.json()["data"]

        return {
            "response": response,
            "note_id": note["id"],
            "note": note,
        }

    def note_exists_in_list(self, token: str, note_id: str) -> bool:
        response = self.notes_client.get_all_notes(token)
        notes = response.json()["data"]
        return any(note["id"] == note_id for note in notes)

