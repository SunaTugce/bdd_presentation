utilities/notes_page.py -------
from playwright.sync_api import Page, expect


class NotesPage:
    URL = "https://practice.expandtesting.com/notes/app"

    def __init__(self, page: Page):
        self.page = page

    def open(self):
        self.page.goto(self.URL)

    def login(self, email: str, password: str):
        self.open()

        # Selector'lar sayfadaki gerçek DOM'a göre küçük revize isteyebilir.
        self.page.get_by_test_id("login-email").fill(email)
        self.page.get_by_test_id("login-password").fill(password)
        self.page.get_by_test_id("login-submit").click()

    def open_create_note_form(self):
        self.page.get_by_role("button", name="Add Note").click()

    def verify_create_note_form_is_visible(self):
        expect(self.page.get_by_text("Add new note")).to_be_visible()

    def verify_title_and_description_are_available(self):
        expect(self.page.get_by_test_id("note-title")).to_be_visible()
        expect(self.page.get_by_test_id("note-description")).to_be_visible()

tests/notest_creation_ui_steps.py --------
from pytest_bdd import scenarios, given, when, then


scenarios("../../features/notes_creation_ui.feature")


@given("an authenticated user is on the notes page")
def authenticated_user_is_on_notes_page(notes_page):
    # Eğitim için örnek user. Gerçek demo öncesi kullanıcıyı app/API üzerinden oluşturman daha güvenli olur.
    notes_page.login(
        email="bdd_user@test.com",
        password="Password123!"
    )


@when("the user starts creating a new note")
def user_starts_creating_note(notes_page):
    notes_page.open_create_note_form()


@then("the create note form should be displayed")
def create_note_form_should_be_displayed(notes_page):
    notes_page.verify_create_note_form_is_visible()


@then("the form should allow entering a title and description")
def form_should_allow_title_and_description(notes_page):
    notes_page.verify_title_and_description_are_available()

