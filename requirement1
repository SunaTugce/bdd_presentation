from pytest_bdd import scenarios, given, when, then, parsers


scenarios("../../features/notes_management.feature")


@given("an authenticated user exists")
def authenticated_user_exists(context, auth_client):
    context["user"] = auth_client.create_authenticated_user()


@given(parsers.parse('the user has a note with title "{title}" and description "{description}"'))
def user_has_a_note(context, notes_client, title, description):
    response = notes_client.create_note(
        token=context["user"]["token"],
        title=title,
        description=description,
    )

    assert response.status_code in [200, 201], response.text

    note = response.json()["data"]

    context["note"] = note
    context["note_id"] = note["id"]


@when(parsers.parse('the user creates a note with title "{title}" and description "{description}"'))
def user_creates_note(context, notes_client, title, description):
    response = notes_client.create_note(
        token=context["user"]["token"],
        title=title,
        description=description,
    )

    context["response"] = response

    if response.status_code in [200, 201]:
        note = response.json()["data"]
        context["note"] = note
        context["note_id"] = note["id"]


@when(parsers.parse('the user tries to create a note with title "{title}" and description "{description}"'))
def user_tries_to_create_note(context, notes_client, title, description):
    context["response"] = notes_client.create_note(
        token=context["user"]["token"],
        title=title,
        description=description,
    )


@when("the user deletes the note")
def user_deletes_note(context, notes_client):
    context["response"] = notes_client.delete_note(
        token=context["user"]["token"],
        note_id=context["note_id"],
    )


@then("the note should be created successfully")
def note_should_be_created_successfully(context):
    response = context["response"]

    assert response.status_code in [200, 201], response.text
    assert response.json()["success"] is True
    assert context["note_id"] is not None


@then("the note should be available in the user's notes list")
def note_should_be_available_in_list(context, notes_client):
    assert notes_client.note_exists_in_list(
        token=context["user"]["token"],
        note_id=context["note_id"],
    )


@then("the note should be deleted successfully")
def note_should_be_deleted_successfully(context):
    response = context["response"]

    assert response.status_code == 200, response.text
    assert response.json()["success"] is True


@then("the note should not be available in the user's notes list")
def note_should_not_be_available_in_list(context, notes_client):
    assert not notes_client.note_exists_in_list(
        token=context["user"]["token"],
        note_id=context["note_id"],
    )


@then("the note creation should be rejected")
def note_creation_should_be_rejected(context):
    response = context["response"]

    assert response.status_code in [400, 422], response.text
    assert response.json()["success"] is False


@then(parsers.parse('the error message should mention "{missing_field}"'))
def error_message_should_mention(context, missing_field):
    response_body = context["response"].json()
    message = response_body.get("message", "").lower()

    assert missing_field.lower() in message

