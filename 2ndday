from pytest_bdd import scenarios, given, when, then
from tests.services.notes_service import NotesService

scenarios("../../features/notes.feature")


@given("an authenticated user exists")
def authenticated_user(context):
    context["user"] = {
        "username": "test_user",
        "authenticated": True
    }


@when('the user creates a note with title "Shopping List"')
def create_note(context):
    service = NotesService()
    context["response"] = service.create_note("Shopping List")


@then("the note should be created successfully")
def verify_note_created(context):
    assert context["response"]["success"] is True
    assert context["response"]["title"] == "Shopping List"



