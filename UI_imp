from pytest_bdd import scenarios, given, when, then, parsers


scenarios("../../features/notes_ui.feature")


@given("an authenticated user exists")
def authenticated_user_exists(context, notes_page, test_user):
    # Eğitimde basitlik için burada login gösteriyoruz.
    # Gerçek projede kullanıcıyı API ile create edip UI'da login olmak daha stabil olur.
    notes_page.login(
        email=test_user["email"],
        password=test_user["password"],
    )

    context["user"] = test_user


@given(parsers.parse('the user has a note with title "{title}" and description "{description}"'))
def user_has_a_note(context, notes_page, title, description):
    notes_page.create_note_successfully(title, description)
    context["note_title"] = title
    context["note_description"] = description


@when(parsers.parse('the user creates a note with title "{title}" and description "{description}"'))
def user_creates_note(context, notes_page, title, description):
    notes_page.create_note(title, description)
    context["note_title"] = title
    context["note_description"] = description


@when(parsers.parse('the user tries to create a note with title "{title}" and description "{description}"'))
def user_tries_to_create_note(context, notes_page, title, description):
    notes_page.create_note(title, description)
    context["missing_title"] = title
    context["missing_description"] = description


@when("the user deletes the note")
def user_deletes_note(context, notes_page):
    notes_page.delete_note(context["note_title"])


@then("the note should be created successfully")
def note_should_be_created_successfully(context, notes_page):
    notes_page.note_should_be_visible(context["note_title"])


@then("the note should be available in the user's notes list")
def note_should_be_available_in_list(context, notes_page):
    notes_page.note_should_be_visible(context["note_title"])


@then("the note should be deleted successfully")
def note_should_be_deleted_successfully(context):
    # UI'da delete success toast/message varsa burada kontrol edilebilir.
    # Eğitim için asıl observable sonuç bir sonraki But step'inde doğrulanıyor.
    assert True


@then("the note should not be available in the user's notes list")
def note_should_not_be_available_in_list(context, notes_page):
    notes_page.note_should_not_be_visible(context["note_title"])


@then("the note creation should be rejected")
def note_creation_should_be_rejected(context, notes_page):
    # UI'da rejected davranışı: note listede görünmemeli.
    if context.get("note_title"):
        notes_page.note_should_not_be_visible(context["note_title"])


@then(parsers.parse('the error message should mention "{missing_field}"'))
def error_message_should_mention(context, notes_page, missing_field):
    notes_page.validation_error_should_mention(missing_field)



