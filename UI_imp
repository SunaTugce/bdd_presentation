from playwright.sync_api import Page, expect


class NotesPage:
    URL = "https://practice.expandtesting.com/notes/app"

    def __init__(self, page: Page):
        self.page = page

    def login(self, email: str, password: str) -> None:
        self.page.goto(self.URL)

        self.page.get_by_role("link", name="Login").click()
        self.page.get_by_label("Email address").fill(email)
        self.page.get_by_label("Password").fill(password)
        self.page.get_by_role("button", name="Login").click()

        expect(self.page.get_by_role("button", name="Add Note")).to_be_visible()

    def create_note(self, title: str, description: str) -> None:
        self.page.get_by_role("button", name="Add Note").click()

        if title:
            self.page.get_by_label("Title").fill(title)

        if description:
            self.page.get_by_label("Description").fill(description)

        self.page.get_by_role("button", name="Create").click()

    def create_note_successfully(self, title: str, description: str) -> None:
        self.create_note(title, description)
        expect(self.page.get_by_text(title)).to_be_visible()

    def note_should_be_visible(self, title: str) -> None:
        expect(self.page.get_by_text(title)).to_be_visible()

    def note_should_not_be_visible(self, title: str) -> None:
        expect(self.page.get_by_text(title)).not_to_be_visible()

    def delete_note(self, title: str) -> None:
        note_card = self.page.locator(".card").filter(has_text=title)
        note_card.get_by_role("button", name="Delete").click()

        # Eğer confirmation modal çıkarsa:
        if self.page.get_by_role("button", name="Delete").is_visible():
            self.page.get_by_role("button", name="Delete").click()

    def validation_error_should_mention(self, missing_field: str) -> None:
        expect(
            self.page.get_by_text(missing_field, exact=False)
        ).to_be_visible()




